---
import { site as commonSite } from '@spscommon/data/site';
import { site as customSite } from '@spscustom/data/site';

const base = import.meta.env.BASE_URL;
---

{customSite.navEnable && (
  <div class="hero-buttons">
    {
      customSite.navigations.map((nav, index) => {
        if (index === 0) {
          return (
            <a href={`${base}${nav.path}`} class="btn btn-primary tiks-success tiks-hover">
              <span set:html={nav.label}></span>
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
          );
        } else {
          return (
            <a href={`${base}${nav.path}`} class="btn btn-secondary tiks-success tiks-hover">
              <span set:html={nav.label}></span>
            </a>
          );
        }
      })
    }
  </div>
)}


{customSite.homeSiteEnable && (
  <div class="hero-buttons">
    {
      commonSite.homeSiteLinks
    .filter((homeSite) => homeSite.theme !== customSite.theme)
    .map((homeSite, index) => {
        if (index === 0) {
          return (
            <a href={homeSite.href} class="btn btn-primary tiks-success tiks-hover" target="_blank" rel="noopener noreferrer">
              <span set:html={homeSite.title}></span>
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
          );
        } else {
          return (
            <a href={homeSite.href} class="btn btn-secondary tiks-success tiks-hover" target="_blank" rel="noopener noreferrer">
              <span set:html={homeSite.title}></span>
            </a>
          );
        }
      })
    }
  </div>
)}


<style>

  .hero-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    font-size: 1rem;
    font-weight: 600;
    font-family: var(--sps-hero-font-family);
    border: none;
    border-radius: 0.5rem;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-primary {
    background: var(--sps-hero-title-color-primary);
    color: var(--sps-hero-btn-primary-text-color);
    box-shadow: 0 4px 14px rgba(59, 130, 246, 0.4);
  }

  .btn-primary:hover {
    background: #2563EB;
    box-shadow: 0 6px 20px rgba(59, 130, 246, 0.5);
  }

  .btn-primary svg {
    transition: transform 0.2s ease;
  }

  .btn-primary:hover svg {
    transform: translateX(4px);
  }

  .btn-secondary {
    background: transparent;
    color: var(--sps-hero-btn-secondary-text-color);
    border: 1px solid var(--sps-hero-title-color-border);
  }

  .btn-secondary:hover {
    background: rgba(59, 130, 246, 0.1);
    border-color: var(--sps-hero-title-color-primary);
  }

</style>


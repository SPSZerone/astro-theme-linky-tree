---
import HeroHome from '@spscommon/components/hero/Home.astro';
import HomeQuote from '@spscommon/components/hero/HomeQuote.astro';
import Buttons from './Buttons.astro';
import TechStack from './TechStack.astro';

// Hero section - Clean, professional design
// const base = import.meta.env.BASE_URL;
---

<section class="hero">
  <div class="hero-content">
    <div class="greeting">Hello, I'm</div>
    <h1 class="hero-title">
      <span class="title-text">William Chen <br> 陈威</span>
    </h1>
    <p class="hero-description">
      <HeroHome />
    </p>

    <Buttons />
    <HomeQuote />
    <TechStack />

  </div>

  <!-- Decorative elements -->
  <div class="hero-decoration">
    <div class="glow glow-1"></div>
    <div class="glow glow-2"></div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding: calc(var(--sps-hero-nav-height) + 2rem) 2rem 4rem;
  }

  .hero-content {
    text-align: center;
    z-index: 10;
    max-width: 800px;
    animation: fadeInUp 0.8s ease-out;
  }

  .greeting {
    font-family: var(--sps-hero-font-family);
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--sps-hero-greeting-text-color);
    margin-bottom: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .hero-title {
    font-family: var(--sps-hero-font-family);
    font-size: clamp(3rem, 12vw, 7rem);
    font-weight: 700;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .title-text {
    background: linear-gradient(135deg, var(--sps-hero-title-color-text) 0%, var(--sps-hero-title-color-primary) 50%, var(--sps-hero-title-color-accent-purple) 100%);
    background-size: 200% auto;
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: gradientFlow 4s ease infinite;
  }

  @keyframes gradientFlow {
    0%, 100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  /* Decorative glows */
  .hero-decoration {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.4;
  }

  .glow-1 {
    width: 400px;
    height: 400px;
    background: var(--sps-hero-title-color-primary);
    top: 10%;
    left: 10%;
    animation: float 8s ease-in-out infinite;
  }

  .glow-2 {
    width: 300px;
    height: 300px;
    background: var(--sps-hero-title-color-accent-purple);
    bottom: 20%;
    right: 10%;
    animation: float 6s ease-in-out infinite reverse;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes float {
    0%, 100% {
      transform: translate(0, 0);
    }
    50% {
      transform: translate(20px, -20px);
    }
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .title-text {
      animation: none;
    }
    .glow-1, .glow-2 {
      animation: none;
    }
    .hero-content {
      animation: none;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding-top: calc(var(--sps-hero-nav-height) + 3rem);
    }

    .hero-buttons {
      flex-direction: column;
      align-items: center;
    }

    .btn {
      width: 100%;
      max-width: 280px;
      justify-content: center;
    }
  }
</style>

---
import { site } from '@spstheme/data/site';

const base = import.meta.env.BASE_URL;
---


<div class="hero-buttons">
  {
    site.linkCards.map((card, index) => {
    if (index === 0) {
        return (
          <a href={card.href} class="btn btn-primary tiks-success tiks-hover" target="_blank" rel="noopener noreferrer">
            <span set:html={card.title}></span>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        );
      } else {
        return (
          <a href={card.href} class="btn btn-secondary tiks-success tiks-hover" target="_blank" rel="noopener noreferrer">
            <span set:html={card.title}></span>
          </a>
        );
      }
    })
  }
</div>


